# Copy this file to ".env" and fill in your Firebase project values.
# Firebase Console → Project settings → General → Your apps → SDK setup & configuration.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# PIN that unlocks the Owner Dashboard (defaults to 1234 if left blank).
VITE_OWNER_PIN=1234
